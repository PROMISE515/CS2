{
    "name": "cs2-coach",
    "version": "1.0.0",
    "description": "CS2 AI 教练 - 实时战术建议",
    "author": "BBAL2025",
    "private": true,
    "main": "electron/main.js",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "build:electron": "tsc -p tsconfig.electron.json",
        "start": "next start",
        "lint": "next lint",
        "electron:dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
        "electron:build": "npm run build && npm run build:electron && electron-builder",
        "package:win": "npm run build && npm run build:electron && electron-builder --win",
        "package:mac": "npm run build && npm run build:electron && electron-builder --mac"
    },
    "dependencies": {
        "@pusher/push-notifications-server": "^1.2.2",
        "@pusher/push-notifications-web": "^1.0.9",
        "clsx": "latest",
        "lucide-react": "latest",
        "next": "latest",
        "pusher": "^5.1.2",
        "pusher-js": "^8.0.1",
        "react": "latest",
        "react-dom": "latest",
        "tailwind-merge": "latest"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.1.18",
        "@types/express": "^5.0.6",
        "@types/node": "latest",
        "@types/react": "latest",
        "@types/react-dom": "latest",
        "autoprefixer": "latest",
        "concurrently": "^9.1.2",
        "electron": "^35.7.5",
        "electron-builder": "^26.0.0",
        "express": "^5.2.1",
        "postcss": "latest",
        "tailwindcss": "latest",
        "tsx": "^4.19.0",
        "typescript": "latest",
        "wait-on": "^8.0.3"
    }
}
