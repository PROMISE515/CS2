{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": ["ES2020"],
        "outDir": "./dist-electron",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": false,
        "declarationMap": false,
        "sourceMap": false
    },
    "include": [
        "electron/**/*.ts",
        "server/**/*.ts",
        "lib/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "app",
        "out",
        "dist"
    ]
}
